package wast:file-manager-hosted@0.1.0;

interface types {
  type type-uid = string;
  type func-uid = string;
  type wit-type-ref = type-uid;

  variant wit-type {
    primitive(primitive-type),
    %option(wit-type-ref),
    %result(tuple<wit-type-ref, wit-type-ref>),
    %list(wit-type-ref),
    %record(list<tuple<type-uid, wit-type-ref>>),
    %variant(list<tuple<type-uid, option<wit-type-ref>>>),
    %tuple(list<wit-type-ref>),
  }

  enum primitive-type {
    %u32,
    %u64,
    %i32,
    %i64,
    %f32,
    %f64,
    %bool,
    %char,
    %string,
  }

  variant func-source {
    internal(func-uid),
    imported(func-uid),
    exported(func-uid),
  }

  variant type-source {
    internal(type-uid),
    imported(type-uid),
    exported(type-uid),
  }

  record wast-func {
    source: func-source,
    params: list<tuple<func-uid, wit-type-ref>>,
    %result: option<wit-type-ref>,
    body: option<list<u8>>,
  }

  record wast-type-def {
    source: type-source,
    definition: wit-type,
  }

  record sym-entry {
    uid: string,
    display-name: string,
  }

  record syms {
    wit-syms: list<tuple<string, string>>,
    internal: list<sym-entry>,
    local: list<sym-entry>,
  }

  record wast-component {
    funcs: list<tuple<func-uid, wast-func>>,
    types: list<tuple<type-uid, wast-type-def>>,
    syms: syms,
  }

  record component-files {
    wast-db: list<u8>,
    syms-en-yaml: option<list<u8>>,
  }

  record wast-error {
    message: string,
    location: option<string>,
  }
}

interface file-manager-bindgen {
  use types.{component-files, wast-component, wast-error};
  bindgen: func(world-wit: list<u8>) -> result<component-files, wast-error>;
  read: func(wast-db: list<u8>, syms-en-yaml: option<list<u8>>) -> result<wast-component, wast-error>;
  write: func(world-wit: list<u8>, component: wast-component) -> result<component-files, wast-error>;
  merge: func(world-wit: list<u8>, full: component-files, partial: wast-component) -> result<component-files, wast-error>;
}

world file-manager-hosted-world {
  export file-manager-bindgen;
}
