package wast:sample;

world component {
  export sum-of-squares: func(a: u32, b: u32) -> u32;
  export max3: func(a: u32, b: u32, c: u32) -> u32;
  export evaluate: func(x: u32) -> u32;
  export make-point: func(x: u32, y: u32) -> point;
  export get-x: func(p: point) -> u32;
  export unwrap-or: func(o: option<u32>, default: u32) -> u32;
  export greeting: func() -> string;
}
