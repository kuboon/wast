{
  "name": "@wast/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "WAST",
  "description": "WAST language support for VS Code",
  "engines": {
    "vscode": "^1.100.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/wast.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wast-explorer",
          "title": "WAST",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "views": {
      "wast-explorer": [
        {
          "id": "wastComponents",
          "name": "Components"
        }
      ]
    },
    "configuration": {
      "title": "WAST",
      "properties": {
        "wast.symsLanguage": {
          "type": "string",
          "default": "en",
          "description": "Syms language suffix"
        },
        "wast.syntaxPlugin": {
          "type": "string",
          "default": "ruby-like",
          "enum": [
            "ruby-like",
            "ts-like",
            "rust-like"
          ],
          "description": "Syntax plugin for text conversion"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "echo \"no tests yet\"",
    "lint": "echo \"no linter configured yet\""
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.0"
  }
}
