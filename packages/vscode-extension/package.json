{
  "name": "@wast/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "WAST",
  "description": "WAST language support for VS Code",
  "engines": {
    "vscode": "^1.100.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/wast.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "wast.compileComponent",
        "title": "WAST: Compile current component",
        "category": "WAST"
      },
      {
        "command": "wast.refreshTree",
        "title": "WAST: Refresh tree",
        "category": "WAST",
        "icon": "$(refresh)"
      },
      {
        "command": "wast.openSelected",
        "title": "WAST: Open selected",
        "category": "WAST",
        "icon": "$(go-to-file)"
      },
      {
        "command": "wast.clearSelection",
        "title": "WAST: Clear selection",
        "category": "WAST",
        "icon": "$(clear-all)"
      },
      {
        "command": "wast.toggleCallers",
        "title": "WAST: Toggle +callers",
        "category": "WAST",
        "icon": "$(call-incoming)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "wast.openSelected",
          "when": "view == wastComponents",
          "group": "navigation@1"
        },
        {
          "command": "wast.clearSelection",
          "when": "view == wastComponents",
          "group": "navigation@2"
        },
        {
          "command": "wast.refreshTree",
          "when": "view == wastComponents",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "wast.compileComponent",
          "when": "view == wastComponents && viewItem == wastComponent",
          "group": "wast"
        },
        {
          "command": "wast.toggleCallers",
          "when": "view == wastComponents && viewItem =~ /^wastFunc/",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wast-explorer",
          "title": "WAST",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "views": {
      "wast-explorer": [
        {
          "id": "wastComponents",
          "name": "Components"
        }
      ]
    },
    "configuration": {
      "title": "WAST",
      "properties": {
        "wast.symsLanguage": {
          "type": "string",
          "default": "en",
          "description": "Syms language suffix"
        },
        "wast.syntaxPlugin": {
          "type": "string",
          "default": "ruby-like",
          "enum": [
            "raw",
            "ruby-like",
            "ts-like",
            "rust-like"
          ],
          "description": "Syntax plugin for text conversion"
        }
      }
    }
  },
  "scripts": {
    "bundle-components": "node scripts/bundle-components.mjs",
    "build": "pnpm bundle-components && tsc",
    "seed-example": "node scripts/seed-example.mjs",
    "test": "node --test 'test/*.test.mjs'",
    "lint": "echo \"no linter configured yet\""
  },
  "dependencies": {
    "@bytecodealliance/preview2-shim": "^0.17.9"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.19.0",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.118.0",
    "typescript": "^5.9.3"
  }
}
